---
// src/pages/servicios.astro

// Datos estructurados para SEO
const services = [
  {
    title: "Constitución de Empresas en La Paz",
    slug: "constitucion-empresas-la-paz",
    description:
      "Trámites SEPREC para constituir S.R.L. y S.A. en Bolivia. Asesoría legal completa para registrar tu empresa en La Paz.",
    keywords: [
      "constituir empresa La Paz",
      "tramite SEPREC",
      "S.R.L. Bolivia",
      "registrar empresa Bolivia",
    ],
  },
  {
    title: "Declaraciones Juradas Impuestos Nacionales",
    slug: "declaraciones-juradas-impuestos-nacionales",
    description:
      "Presentación de IVA, IT, IUE y Formulario 605. Cumplimiento tributario mensual y anual para empresas bolivianas.",
    keywords: [
      "declaraciones juradas Bolivia",
      "IVA Bolivia",
      "IUE Bolivia",
      "formulario 605",
      "impuestos nacionales",
    ],
  },
  {
    title: "Auditoría Financiera y Tributaria",
    slug: "auditoria-financiera-tributaria",
    description:
      "Auditorías internas y externas con estándares internacionales. Diagnóstico completo de riesgos financieros y tributarios.",
    keywords: [
      "auditoria financiera La Paz",
      "auditoria tributaria Bolivia",
      "auditor externo Bolivia",
    ],
  },
  {
    title: "Contabilidad para PYMEs",
    slug: "contabilidad-pymes-la-paz",
    description:
      "Servicios contables especializados para pequeñas y medianas empresas. Registro SIAT, balances y estados financieros.",
    keywords: [
      "contabilidad PYMEs La Paz",
      "registro SIAT",
      "balances Bolivia",
      "contador La Paz",
    ],
  },
  {
    title: "Trámites SICOES y RUPE",
    slug: "tramites-sicoes-rupe",
    description:
      "Registro en SICOES, RUPE y PROBOLIVIA para proveedores del Estado. Certificaciones y habilitaciones vigentes.",
    keywords: [
      "SICOES Bolivia",
      "RUPE Bolivia",
      "PROBOLIVIA",
      "proveedor Estado Bolivia",
    ],
  },
  {
    title: "Asesoría Laboral y AFP",
    slug: "asesoria-laboral-afp",
    description:
      "Gestión de planillas, seguros en cajas de salud y trámites en Gestora Pública. Cumplimiento normativo laboral.",
    keywords: [
      "asesoria laboral Bolivia",
      "AFP Bolivia",
      "caja salud Bolivia",
      "planillas laborales La Paz",
    ],
  },
];

// JSON-LD para servicios múltiples
const jsonLdServices = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: services.map((service, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Service",
      name: service.title,
      description: service.description,
      provider: {
        "@type": "AccountingService",
        name: "GLOBALCONT AUDIT SOLUTION S.R.L.",
      },
      areaServed: {
        "@type": "City",
        name: "La Paz",
        containedIn: {
          "@type": "Country",
          name: "Bolivia",
        },
      },
    },
  })),
};
---

