---
// src/components/ContactSection.astro
interface Props {
  companyInfo?: {
    address: string;
    phone: string;
    email: string;
    hours: string;
    nit: string;
  };
}

const defaultInfo = {
  address: "Calle Rosendo Gutiérrez #255, La Paz",
  phone: "76063400",
  email: "contacto@globalcont.bo",
  hours: "Lun - Vie: 9:00 - 18:00",
  nit: "621771025",
};

const { companyInfo = defaultInfo } = Astro.props;

// Obtener plan seleccionado desde URL params (opcional)
const url = new URL(Astro.request.url);
const selectedPlan = url.searchParams.get("plan") || "";
---

<section
  id="contacto"
  class="relative py-20 lg:py-28 bg-primary overflow-hidden"
>
  <div
    class="w-52 h-32 bg-white top-5 -right-30 absolute rounded-full blur-1xl"
  >
  </div>
  <div
    class="w-full h-20 md:h-50 bg-[url('/mar_decorative.svg')] bg-contain bg-no-repeat opacity-30 pointer-events-none top-0 absolute mix-blend-plus-darker"
  >
  </div>
  <!-- Decorative -->
  <!-- <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-0 left-1/4 w-96 h-96 bg-gold/35 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 right-1/4 w-64 h-64 bg-accent/35 rounded-full blur-3xl"
    >
    </div>
  </div> -->

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span
        class="inline-flex items-center px-3 py-1 rounded-full bg-white/10 text-gold text-sm font-medium mb-4"
      >
        Hablemos de tu proyecto
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Comienza con una consulta gratuita
      </h2>
      <p class="text-lg text-white/80 leading-relaxed">
        Cuéntanos sobre tu empresa y te ayudaremos a elegir el plan perfecto.
        Sin compromiso, sin letra chica.
      </p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8 lg:gap-12">
      <!-- Info Column -->
      <div class="lg:col-span-1 space-y-6">
        <!-- Contact Cards -->
        <div
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6"
        >
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-10 h-10 rounded-lg bg-accent/20 flex items-center justify-center"
            >
              <svg
                class="w-5 h-5 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
            </div>
            <h3 class="text-white font-semibold">Teléfono / WhatsApp</h3>
          </div>
          <a
            href={`tel:+591${companyInfo.phone}`}
            class="text-white/80 hover:text-accent transition-colors"
          >
            +591 {companyInfo.phone}
          </a>
          <a
            href={`https://wa.me/591${companyInfo.phone}?text=${encodeURIComponent("Hola, me interesa una asesoría contable")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 mt-2 text-sm text-accent hover:text-accent/80 font-medium"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.4c1.038 2.506 3.082 4.08 5.21 4.487.61.116 1.198.116 1.758.029.535-.085 1.648-.672 1.885-1.323.237-.65.237-1.207.163-1.331-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"
              ></path>
            </svg>
            Escríbenos por WhatsApp
          </a>
        </div>

        <div
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6"
        >
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-10 h-10 rounded-lg bg-accent/20 flex items-center justify-center"
            >
              <svg
                class="w-5 h-5 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                ></path>
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </div>
            <h3 class="text-white font-semibold">Dirección</h3>
          </div>
          <p class="text-white/80 text-sm">{companyInfo.address}</p>
        </div>

        <div
          class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-xl p-6"
        >
          <div class="flex items-center gap-3 mb-3">
            <div
              class="w-10 h-10 rounded-lg bg-accent/20 flex items-center justify-center"
            >
              <svg
                class="w-5 h-5 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-white font-semibold">Horario de Atención</h3>
          </div>
          <p class="text-white/80 text-sm">{companyInfo.hours}</p>
        </div>

        <!-- Trust badges -->
        <div class="pt-6 border-t border-white/10">
          <div class="flex items-center gap-2 text-white/60 text-xs mb-2">
            <svg
              class="w-4 h-4 text-gold"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Respuesta en menos de 24 horas</span>
          </div>
          <div class="flex items-center gap-2 text-white/60 text-xs">
            <svg
              class="w-4 h-4 text-gold"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"></path>
            </svg>
            <span>Confidencialidad 100% garantizada</span>
          </div>
        </div>
      </div>

      <!-- Form Column -->
      <div class="lg:col-span-2">
        <form
          class="bg-white rounded-2xl p-6 lg:p-8 shadow-2xl"
          action="/api/contact"
          method="POST"
        >
          <!-- Hidden field for selected plan -->
          {
            selectedPlan && (
              <input type="hidden" name="plan" value={selectedPlan} />
            )
          }

          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <!-- Name -->
            <div>
              <label
                for="name"
                class="block text-sm font-medium text-text mb-2"
              >
                Nombre completo *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-bg"
                placeholder="Ej: Juan Pérez"
              />
            </div>

            <!-- Company -->
            <div>
              <label
                for="company"
                class="block text-sm font-medium text-text mb-2"
              >
                Empresa
              </label>
              <input
                type="text"
                id="company"
                name="company"
                class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-bg"
                placeholder="Ej: Mi Empresa S.R.L."
              />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6 mb-6">
            <!-- Email -->
            <div>
              <label
                for="email"
                class="block text-sm font-medium text-text mb-2"
              >
                Correo electrónico *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-bg"
                placeholder="juan@empresa.com"
              />
            </div>

            <!-- Phone -->
            <div>
              <label
                for="phone"
                class="block text-sm font-medium text-text mb-2"
              >
                Teléfono / Celular *
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-bg"
                placeholder="Ej: 7XXXXXXX"
              />
            </div>
          </div>

          <!-- Plan Selection (if not in URL) -->
          {
            !selectedPlan && (
              <div class="mb-6">
                <label
                  for="plan"
                  class="block text-sm font-medium text-text mb-2"
                >
                  Plan de interés
                </label>
                <select
                  id="plan"
                  name="plan"
                  class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-bg"
                >
                  <option value="">Selecciona un plan</option>
                  <option value="basico">Básico - Contabilidad mensual</option>
                  <option value="pro">Pro - Contabilidad + Impuestos</option>
                  <option value="premium">Premium - Auditoría completa</option>
                  <option value="otro">Aún no estoy seguro</option>
                </select>
              </div>
            )
          }

          <!-- Message -->
          <div class="mb-6">
            <label
              for="message"
              class="block text-sm font-medium text-text mb-2"
            >
              Cuéntanos sobre tu empresa *
            </label>
            <textarea
              id="message"
              name="message"
              rows={4}
              required
              class="w-full px-4 py-3 rounded-lg border border-border focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-bg resize-none"
              placeholder="Ej: Somos una empresa de servicios con 5 empleados, necesitamos ayuda con declaraciones de impuestos y contabilidad mensual..."
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full bg-accent text-white font-semibold px-6 py-4 rounded-lg shadow-lg shadow-accent/25 hover:bg-accent/90 hover:shadow-accent/30 transition-all duration-200 flex items-center justify-center gap-2 group"
          >
            Enviar consulta gratuita
            <svg
              class="w-5 h-5 group-hover:translate-x-1 transition-transform"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </button>

          <p class="mt-4 text-xs text-text-light text-center">
            Al enviar, aceptas nuestra política de privacidad. Tus datos están
            protegidos.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
