---
// src/components/Footer.astro
interface Props {
  companyName?: string;
  tagline?: string;
  address?: string;
  phone?: string;
  email?: string;
  nit?: string;
  registration?: string;
  copyrightYear?: number;
}

const {
  companyName = "GLOBALCONT",
  tagline = "Consultora Contable Legal y Tributaria",
  address = "Calle Rosendo Gutiérrez #255, La Paz - Bolivia",
  phone = "76063400",
  email = "contacto@globalcont.bo",
  nit = "621771025",
  registration = "621771025",
  copyrightYear = new Date().getFullYear(),
} = Astro.props;

const navLinks = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "#servicios" },
  { label: "Proceso", href: "#proceso" },
  { label: "Planes", href: "#planes" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Contacto", href: "#contacto" },
];

const socialLinks = [
  {
    name: "Facebook",
    href: "https://www.facebook.com/globalcont.bo/",
    iconPath: "facebook.svg",
  },
  {
    name: "Tiktok",
    href: "https://www.tiktok.com/@globalcontbolivia",
    iconPath: "tiktok.svg",
  },
  {
    name: "Instagram",
    href: "https://www.instagram.com/globalcont.lp/",
    iconPath: "instagram.svg",
  },
  {
    name: "WhatsApp",
    href: `https://wa.me/591${phone}`,
    iconPath: "whatsapp.svg",
  },
];
---

<footer id="footer" class="bg-primary text-white relative overflow-hidden">
  <!-- Subtle top glow -->
  <div
    class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"
    aria-hidden="true"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-8">
    <!-- Main Grid -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12 mb-12"
    >
      <!-- Column 1: Brand -->
      <div class="space-y-4">
        <h3 class="text-2xl font-bold tracking-tight text-white">
          {companyName}
        </h3>
        <p class="text-gold text-sm font-medium">{tagline}</p>
        <p class="text-white/70 text-sm leading-relaxed">
          Transformamos la complejidad contable en claridad para la toma de
          decisiones. Cumplimiento, transparencia y estrategia para empresas
          bolivianas.
        </p>
        <div class="pt-2 space-y-1 text-xs text-white/50">
          <p>NIT: {nit}</p>
          <p>Matrícula: {registration}</p>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h4 class="text-white font-semibold mb-4">Navegación</h4>
        <ul class="space-y-3" role="list">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-white/70 hover:text-accent transition-colors text-sm inline-flex items-center gap-2 group"
                >
                  <span class="w-1 h-1 rounded-full bg-white/30 group-hover:bg-accent transition-colors" />
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Column 3: Contact Info -->
      <div>
        <h4 class="text-white font-semibold mb-4">Contacto Directo</h4>
        <ul class="space-y-4" role="list">
          <li class="flex items-start gap-3">
            <svg
              class="w-5 h-5 text-gold shrink-0 mt-0.5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
            >
            <span class="text-white/70 text-sm">{address}</span>
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-5 h-5 text-gold shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg
            >
            <a
              href={`tel:+591${phone}`}
              class="text-white/70 hover:text-accent text-sm transition-colors"
              >+591 {phone}</a
            >
          </li>
          <li class="flex items-center gap-3">
            <svg
              class="w-5 h-5 text-gold shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
            <a
              href={`mailto:${email}`}
              class="text-white/70 hover:text-accent text-sm transition-colors"
              >{email}</a
            >
          </li>
        </ul>
      </div>

      <!-- Column 4: Social & Trust -->
      <div>
        <h4 class="text-white font-semibold mb-4">Síguenos</h4>
        <div class="flex items-center gap-3 mb-6">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                target={social.href.startsWith("http") ? "_blank" : undefined}
                rel="noopener noreferrer"
                class="w-10 h-10 rounded-lg  hover:bg-accent/20 flex items-center justify-center text-white/70 hover:text-accent transition-all duration-200 group"
                aria-label={social.name}
              >
                <img
                  src={social.iconPath}
                  alt={social.name}
                  width="29"
                  height="29"
                />
              </a>
            ))
          }
        </div>
        <div class="bg-white/5 rounded-lg p-4 border border-white/10">
          <p class="text-xs text-white/60 leading-snug">
            ✅ Registro vigente ante <span class="text-white/80 font-medium"
              >SEPREC</span
            > y <span class="text-white/80 font-medium"
              >Impuestos Nacionales</span
            >. Cumplimos con la normativa contable y tributaria boliviana
            vigente.
          </p>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-white/50 text-sm text-center md:text-left">
        © {copyrightYear}
        {companyName}. Todos los derechos reservados.
      </p>
      <div class="flex flex-wrap justify-center gap-6 text-sm">
        <a
          href="/privacidad"
          class="text-white/50 hover:text-white/80 transition-colors"
          >Política de Privacidad</a
        >
        <a
          href="/terminos"
          class="text-white/50 hover:text-white/80 transition-colors"
          >Términos de Servicio</a
        >
        <a
          href="/cookies"
          class="text-white/50 hover:text-white/80 transition-colors">Cookies</a
        >
      </div>
    </div>
  </div>
</footer>
