---
// src/components/AboutSection.astro
interface Props {
  companyData?: {
    legalName: string;
    commercialName: string;
    registration: { current: string; previous?: string };
    nit: string;
    activities: string[];
    companyType: string;
    location: { dept: string; province: string; municipality: string };
    address: string;
    phone: string;
  };
}

const defaultData = {
  legalName: "GLOBALCONT AUDIT SOLUTION S.R.L.",
  commercialName: "Global Cont",
  registration: {
    current: "621771025",
    previous: "00374014",
  },
  nit: "621771025",
  activities: [
    "Servicios de contabilidad, teneduría de libros y auditorías",
    "Asesoramiento en materia de impuestos",
    "Auditoría financiera, operativa, tributaria, interna y externa",
    "Trámites y asesoramiento estratégico en instituciones públicas y privadas",
    "Capacitaciones y asesorías profesionales especializadas",
  ],
  companyType: "Sociedad de Responsabilidad Limitada",
  location: {
    dept: "La Paz",
    province: "Murillo",
    municipality: "La Paz",
  },
  address: "Calle Rosendo Gutiérrez #255",
  phone: "76063400",
};
// AÑADIR MAPA E IMAGEN
const { companyData = defaultData } = Astro.props;
---

<section id="nosotros" class="relative py-20 lg:py-28 bg-white overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-primary/5 to-transparent"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-64 h-64 bg-gold/5 rounded-full blur-3xl"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
      <!-- Columna izquierda: Visual + Badges -->
      <div class="space-y-8">
        <!-- Imagen principal / Visual -->
        <div class="relative">
          <div
            class="absolute -inset-2 border-2 border-gold/30 rounded-2xl rotate-1"
            aria-hidden="true"
          >
          </div>
          <div
            class="relative bg-gradient-to-br from-primary to-primary/90 rounded-2xl p-8 text-white shadow-xl shadow-primary/20"
          >
            <div class="flex items-center gap-4 mb-6">
              <div
                class="w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center backdrop-blur-sm"
              >
                <svg
                  class="w-7 h-7 text-gold"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="text-gold font-medium text-sm">Razón Social</p>
                <h3 class="text-lg font-bold leading-tight text-white/90">
                  {companyData.legalName}
                </h3>
              </div>
            </div>

            <!-- Trust badges -->
            <div class="grid grid-cols-2 gap-3">
              <div class="bg-white/10 rounded-lg p-3 backdrop-blur-sm">
                <p class="text-xs text-white/70">Matrícula Actual</p>
                <p class="font-mono font-bold text-gold">
                  {companyData.registration.current}
                </p>
              </div>
              {
                companyData.registration.previous && (
                  <div class="bg-white/10 rounded-lg p-3 backdrop-blur-sm">
                    <p class="text-xs text-white/70">Matrícula Anterior</p>
                    <p class="font-mono font-bold text-white/90">
                      {companyData.registration.previous}
                    </p>
                  </div>
                )
              }
              <div class="bg-white/10 rounded-lg p-3 backdrop-blur-sm">
                <p class="text-xs text-white/70">NIT</p>
                <p class="font-mono font-bold text-gold">{companyData.nit}</p>
              </div>
              <div class="bg-white/10 rounded-lg p-3 backdrop-blur-sm">
                <p class="text-xs text-white/70">Tipo Societario</p>
                <p class="font-semibold text-sm">{companyData.companyType}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Ubicación -->
        <div class="card flex items-start gap-4">
          <div
            class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center shrink-0"
          >
            <svg
              class="w-5 h-5 text-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <div>
            <p class="font-medium text-primary">Ubicación</p>
            <p class="text-sm text-text-light">
              {companyData.location.dept} • {companyData.location.province} • {
                companyData.location.municipality
              }
            </p>
            <p class="text-sm text-text-light mt-1">{companyData.address}</p>
          </div>
        </div>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d239.08446977364645!2d-68.12693006464129!3d-16.508342147198018!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1ses!2sbo!4v1775407332302!5m2!1ses!2sbo"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>

      <!-- Columna derecha: Contenido -->
      <div class="space-y-8">
        <!-- Header -->
        <div>
          <span
            class="inline-flex items-center px-3 py-1 rounded-full bg-primary/10 text-primary text-sm font-medium mb-4"
          >
            Sobre Nosotros
          </span>
          <h2 class="text-3xl sm:text-4xl font-bold mb-4">
            Experiencia y transparencia en cada servicio
          </h2>
          <p class="text-lg text-text-light leading-relaxed">
            En <strong class="text-primary">{companyData.commercialName}</strong
            >, combinamos expertise técnico con un enfoque personalizado para
            brindar soluciones contables, tributarias y legales que impulsan el
            crecimiento sostenible de tu empresa en Bolivia.
          </p>
        </div>

        <!-- Actividades -->
        <div>
          <h3
            class="text-xl font-bold text-primary mb-4 flex items-center gap-2"
          >
            <svg
              class="w-5 h-5 text-gold"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"
              ></path>
            </svg>
            Nuestros Servicios Principales
          </h3>
          <ul class="space-y-3" role="list">
            {
              companyData.activities.map((activity) => (
                <li class="flex items-start gap-3 group">
                  <svg
                    class="w-5 h-5 text-accent shrink-0 mt-0.5 group-hover:scale-110 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  <span class="text-text-light">{activity}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Contacto rápido -->
        <div class="bg-bg rounded-xl p-6 border border-border">
          <h4 class="font-bold text-primary mb-4">¿Listo para comenzar?</h4>
          <div class="space-y-3">
            <a
              href={`tel:+591${companyData.phone}`}
              class="flex items-center gap-3 text-text-light hover:text-primary transition-colors group"
            >
              <svg
                class="w-5 h-5 text-gold group-hover:scale-110 transition-transform"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              <span class="font-medium">+591 {companyData.phone}</span>
            </a>
            <a
              href={`https://wa.me/591${companyData.phone}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-accent hover:text-accent/80 font-medium transition-colors"
            >
              <svg
                class="w-4 h-4"
                fill="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.4c1.038 2.506 3.082 4.08 5.21 4.487.61.116 1.198.116 1.758.029.535-.085 1.648-.672 1.885-1.323.237-.65.237-1.207.163-1.331-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"
                ></path>
              </svg>
              Escríbenos por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AccountingService",
    "name": "GLOBALCONT AUDIT SOLUTION S.R.L.",
    "legalName": "GLOBALCONT AUDIT SOLUTION S.R.L.",
    "taxID": "{companyData.nit}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{companyData.address}",
      "addressLocality": "La Paz",
      "addressCountry": "BO"
    },
    "telephone": "+591 {companyData.phone}"
  }
</script>
